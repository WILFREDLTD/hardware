// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["hardware"]
}

// Store Owner/Admin model - Single tenant (Optional, for future multi-tenant expansion)
model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  password               String
  firstName              String
  lastName               String
  phone                  String?
  storeName              String?  @default("My Hardware Store")
  storeLocation          String?
  storeDescription       String?
  autoLockTimeoutMinutes Int?     @default(1)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  hardwareLists         HardwareList[]
  hardwares             Hardware[]
  products              Product[]
  categories            Category[]
  sales                 Sale[]
  debts                 Debt[]
  debtPayments          DebtPayment[]
  reports               Report[]
  inventoryTransactions InventoryTransaction[]

  @@map("users")
  @@schema("hardware")
}

// Product/Item model
model Product {
  id               String   @id @default(cuid())
  name             String
  category         String
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname         String?
  currentStock     Int      @default(0)
  minStockLevel    Int      @default(5)
  baseUnit         String   @default("pcs")
  packageUnitLabel String?
  packageSize      Int?
  supplierName     String   @default("unknown")
  supplierNumber   String   @default("unknown")
  unitPrice        Float
  purchasePrice    Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  saleItems    SaleItem[]
  transactions InventoryTransaction[]

  @@unique([userId, name])
  @@unique([userId, nickname])
  @@index([category])
  @@index([userId])
  @@index([nickname])
  @@map("products")
  @@schema("hardware")
}

// Categories for organizing products
model Category {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@map("categories")
  @@schema("hardware")
}

model BaseUnit {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("base_units")
  @@schema("hardware")
}

// Inventory Transaction model - Track items in/out
model InventoryTransaction {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      TransactionType
  quantity  Int
  notes     String?
  date      DateTime        @default(now())
  createdAt DateTime        @default(now())

  @@index([userId])
  @@index([productId])
  @@index([date])
  @@map("inventory_transactions")
  @@schema("hardware")
}

enum TransactionType {
  IN
  OUT

  @@schema("hardware")
}

// Sale model - Record all sales
model Sale {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  saleDate          DateTime      @default(now())
  subtotalAmount    Float         @default(0)
  discountAmount    Float         @default(0)
  totalAmount       Float
  paymentStatus     PaymentStatus
  discountAppliedBy String?
  discountAppliedAt DateTime?
  supplierName      String        @default("unknown")
  supplierNumber    String        @default("unknown")
  notes             String?
  deletedAt         DateTime?
  deletionReason    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  saleItems SaleItem[]
  debt      Debt?

  @@index([saleDate])
  @@index([paymentStatus])
  @@index([userId])
  @@map("sales")
  @@schema("hardware")
}

enum PaymentStatus {
  PAID
  DEBT

  @@schema("hardware")
}

// Sale Items - Line items in a sale
model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  total     Float
  discount  Float   @default(0)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
  @@schema("hardware")
}

// Debt model - Track credit/debt sales
model Debt {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  saleId      String?    @unique
  sale        Sale?      @relation(fields: [saleId], references: [id], onDelete: SetNull)
  debtorName  String
  debtorPhone String // Phone number for follow-up
  amount      Float
  amountPaid  Float      @default(0)
  date        DateTime   @default(now())
  dueDate     DateTime?
  status      DebtStatus
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  payments DebtPayment[]

  @@index([status])
  @@index([date])
  @@index([debtorPhone])
  @@index([userId])
  @@map("debts")
  @@schema("hardware")
}

enum DebtStatus {
  PENDING
  PARTIAL
  PAID

  @@schema("hardware")
}

// Debt Payment model - Track payments received on debts
model DebtPayment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  debtId    String
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  amount    Float
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([debtId])
  @@index([date])
  @@map("debt_payments")
  @@schema("hardware")
}

// Report model - Store generated reports
model Report {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           ReportType
  period         String
  totalRevenue   Float      @default(0)
  totalSales     Int        @default(0)
  totalDebts     Float      @default(0)
  debtsCollected Float      @default(0)
  debtsPending   Float      @default(0)
  bestSellers    Json? // JSON array of top products
  data           Json?
  generatedAt    DateTime   @default(now())

  @@index([userId])
  @@index([type])
  @@index([period])
  @@map("reports")
  @@schema("hardware")
}

enum ReportType {
  DAILY
  WEEKLY
  MONTHLY

  @@schema("hardware")
}

// Hardware list model - a simple list/category container for hardware items
model HardwareList {
  id          String     @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  hardwares   Hardware[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@map("hardware_lists")
  @@schema("hardware")
}

// Hardware model - represents specialized hardware items (separate from Product)
model Hardware {
  id            String        @id @default(cuid())
  name          String
  listId        String?
  list          HardwareList? @relation(fields: [listId], references: [id], onDelete: SetNull)
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sku           String
  description   String?
  quantity      Int           @default(0)
  unitPrice     Float
  purchasePrice Float
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, sku])
  @@index([listId])
  @@index([userId])
  @@map("hardwares")
  @@schema("hardware")
}
